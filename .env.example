# Environment Configuration Template
# Copy this to .env and fill in your actual values
# DO NOT commit .env to git!

# ==============================================
# Database Configuration (Supabase PostgreSQL)
# ==============================================
DATABASE_URL="postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

# ==============================================
# Authentication
# ==============================================
# JWT secret for token generation (use a random secure string)
JWT_SECRET="your-random-secret-key-min-32-characters"

# JWT token expiration (e.g., "24h", "7d", "30d")
JWT_EXPIRES_IN="24h"

# Bcrypt salt rounds (10 is standard, higher = more secure but slower)
BCRYPT_SALT_ROUNDS=10

# ==============================================
# Server Configuration
# ==============================================
# Port for Express server
PORT=3000

# Node environment
NODE_ENV="development"

# ==============================================
# CORS Configuration
# ==============================================
# Allowed origins (comma-separated for multiple)
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# ==============================================
# Optional: External Services
# ==============================================
# Add any API keys or service credentials here as needed
